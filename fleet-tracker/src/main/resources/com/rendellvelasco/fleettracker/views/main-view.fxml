<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" spacing="10.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.rendellvelasco.fleettracker.controllers.MainViewController">
    <children>
        <Label contentDisplay="TOP" text="VMUMS">
            <font>
                <Font size="36.0" />
            </font>
        </Label>
        <HBox>
            <children>
                <Label text="Vehicle Details">
                    <font>
                        <Font size="24.0" />
                    </font>
                </Label>
            </children>
        </HBox>
        <GridPane hgap="5.0" vgap="10.0">
            <columnConstraints>
                <ColumnConstraints halignment="RIGHT" hgrow="ALWAYS" minWidth="-Infinity" />
                <ColumnConstraints halignment="LEFT" hgrow="ALWAYS" minWidth="-Infinity" />
                <ColumnConstraints halignment="RIGHT" hgrow="ALWAYS" minWidth="-Infinity" />
                <ColumnConstraints halignment="LEFT" hgrow="ALWAYS" minWidth="-Infinity" />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            </rowConstraints>
            <children>
                <Label text="Make:" />
                <Label text="Model:" GridPane.columnIndex="2" />
                <Label text="Year:" GridPane.rowIndex="1" />
                <Label text="Type:" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                <Button fx:id="saveVehicleButton" mnemonicParsing="false" onAction="#onSaveVehicle" text="Save" GridPane.columnIndex="3" GridPane.rowIndex="2">
                    <font>
                        <Font size="14.0" />
                    </font>
                </Button>
                <TextField fx:id="makeTextField" GridPane.columnIndex="1" />
                <TextField fx:id="yearTextField" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                <TextField fx:id="modelTextField" GridPane.columnIndex="3" />
                <TextField fx:id="typeTextField" GridPane.columnIndex="3" GridPane.rowIndex="1" />
            </children>
            <padding>
                <Insets left="15.0" right="20.0" />
            </padding>
        </GridPane>
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <children>
                <Label text="Select Vehicle">
                    <font>
                        <Font size="24.0" />
                    </font>
                </Label>
                <ComboBox fx:id="vehicleComboBox" onAction="#handleVehicleCombo" />
            </children>
            <VBox.margin>
                <Insets />
            </VBox.margin>
        </HBox>
        <HBox>
            <children>
                <Label text="Usage Log">
                    <font>
                        <Font size="18.0" />
                    </font>
                </Label>
            </children>
        </HBox>
        <GridPane hgap="5.0" vgap="10.0" VBox.vgrow="NEVER">
            <columnConstraints>
                <ColumnConstraints halignment="RIGHT" hgrow="SOMETIMES" minWidth="-Infinity" />
                <ColumnConstraints hgrow="ALWAYS" minWidth="-Infinity" />
                <ColumnConstraints halignment="RIGHT" hgrow="SOMETIMES" minWidth="-Infinity" />
                <ColumnConstraints hgrow="ALWAYS" minWidth="-Infinity" />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            </rowConstraints>
            <children>
                <Label text="Start: " />
                <DatePicker fx:id="startDatePicker" GridPane.columnIndex="1">
                    <GridPane.margin>
                        <Insets right="10.0" />
                    </GridPane.margin>
                </DatePicker>
                <Label text="Distance:" GridPane.rowIndex="1" />
                <TextField fx:id="distanceTextField" GridPane.columnIndex="1" GridPane.rowIndex="1">
                    <GridPane.margin>
                        <Insets right="10.0" />
                    </GridPane.margin>
                </TextField>
                <Label text="End:" GridPane.columnIndex="2" />
                <DatePicker fx:id="endDatePicker" GridPane.columnIndex="3" />
                <Button fx:id="saveUsageLogButton" mnemonicParsing="false" onAction="#onSaveUsage" text="Save" GridPane.columnIndex="3" GridPane.rowIndex="2">
                    <GridPane.margin>
                        <Insets left="10.0" />
                    </GridPane.margin>
                    <font>
                        <Font size="14.0" />
                    </font>
                </Button>
            </children>
            <padding>
                <Insets left="20.0" right="20.0" />
            </padding>
        </GridPane>
        <HBox>
            <children>
                <Label text="Maintenance Record">
                    <font>
                        <Font size="18.0" />
                    </font>
                </Label>
            </children>
        </HBox>
        <GridPane hgap="5.0" vgap="10.0" VBox.vgrow="NEVER">
            <columnConstraints>
                <ColumnConstraints halignment="RIGHT" hgrow="SOMETIMES" minWidth="-Infinity" />
                <ColumnConstraints hgrow="ALWAYS" minWidth="-Infinity" />
                <ColumnConstraints halignment="RIGHT" hgrow="SOMETIMES" minWidth="-Infinity" />
                <ColumnConstraints hgrow="ALWAYS" minWidth="-Infinity" />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            </rowConstraints>
            <children>
                <Label text="Date:" />
                <DatePicker fx:id="maintenanceDatePicker" GridPane.columnIndex="1">
                    <GridPane.margin>
                        <Insets right="10.0" />
                    </GridPane.margin>
                </DatePicker>
                <Label text="Description:" GridPane.rowIndex="1" />
                <Label text="Cost:" GridPane.columnIndex="2" />
                <Button fx:id="saveMaintenanceRecordButton" mnemonicParsing="false" onAction="#onSaveMaintenance" text="Save" GridPane.columnIndex="3" GridPane.rowIndex="2">
                    <font>
                        <Font size="14.0" />
                    </font>
                </Button>
                <TextArea fx:id="descriptionTextArea" prefHeight="200.0" prefWidth="200.0" GridPane.columnIndex="1" GridPane.rowIndex="1" GridPane.rowSpan="2">
                    <GridPane.margin>
                        <Insets right="5.0" />
                    </GridPane.margin>
                </TextArea>
            <TextField fx:id="costTextField" GridPane.columnIndex="3" />
            </children>
            <padding>
                <Insets left="5.0" right="20.0" />
            </padding>
        </GridPane>
        <HBox alignment="TOP_RIGHT" prefWidth="200.0">
            <children>
                <Button fx:id="showSummaryButton" mnemonicParsing="false" onAction="#onOpenSummary" text="Show Summary">
                    <font>
                        <Font size="14.0" />
                    </font>
                </Button>
            </children>
            <VBox.margin>
                <Insets right="20.0" />
            </VBox.margin>
        </HBox>
    </children>
    <opaqueInsets>
        <Insets />
    </opaqueInsets>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
</VBox>
