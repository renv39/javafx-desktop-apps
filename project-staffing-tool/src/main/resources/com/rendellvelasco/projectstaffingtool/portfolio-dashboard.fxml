<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="800.0"
            prefWidth="1000.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.rendellvelasco.projectstaffingtool.controllers.DashboardController">
    <left>
        <VBox BorderPane.alignment="CENTER">
            <children>
                <VBox fillWidth="false" spacing="5.0">
                    <children>
                        <Label text="Search:">
                            <font>
                                <Font size="18.0"/>
                            </font>
                        </Label>
                        <TextField fx:id="searchField" prefHeight="25.0" prefWidth="269.0">
                            <font>
                                <Font size="14.0"/>
                            </font>
                        </TextField>
                        <Label text="Status:">
                            <font>
                                <Font size="18.0"/>
                            </font>
                        </Label>
                        <ChoiceBox fx:id="statusChoiceBox" prefWidth="150.0"/>
                    </children>
                </VBox>
                <Label text="Projects">
                    <font>
                        <Font size="18.0"/>
                    </font>
                </Label>
                <ListView fx:id="projectListView" prefHeight="200.0" prefWidth="250.0" VBox.vgrow="ALWAYS"/>
            </children>
            <BorderPane.margin>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
            </BorderPane.margin>
        </VBox>
    </left>
    <center>
        <VBox prefHeight="200.0" prefWidth="100.0" spacing="10.0" BorderPane.alignment="CENTER">
            <children>
                <VBox alignment="CENTER" prefHeight="108.0" prefWidth="607.0" spacing="10.0">
                    <children>
                        <Label fx:id="projectTitleLabel" text="Select a project">
                            <font>
                                <Font size="18.0"/>
                            </font>
                        </Label>
                        <Label fx:id="projectTypeLabel" alignment="CENTER" text="Type">
                            <font>
                                <Font size="18.0"/>
                            </font>
                        </Label>
                        <Label fx:id="totalCostLabel" prefWidth="80.0" text="\$0.00" textFill="GREEN">
                            <font>
                                <Font size="18.0"/>
                            </font>
                        </Label>
                    </children>
                    <VBox.margin>
                        <Insets top="20.0"/>
                    </VBox.margin>
                </VBox>
                <TableView fx:id="assignmentsTable" prefHeight="441.0" prefWidth="607.0" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="nameColumn" prefWidth="150.0" text="Name"/>
                        <TableColumn fx:id="roleColumn" prefWidth="130.0" text="Role"/>
                        <TableColumn fx:id="hoursColumn" prefWidth="100.0" text="Hours"/>
                        <TableColumn fx:id="costColumn" prefWidth="120.0" text="Cost"/>
                    </columns>
                    <VBox.margin>
                        <Insets top="25.0"/>
                    </VBox.margin>
                </TableView>
                <HBox alignment="CENTER_RIGHT" prefWidth="593.0">
                    <children>
                        <Button fx:id="addMemberButton" mnemonicParsing="false" text="Add Member">
                            <font>
                                <Font size="14.0"/>
                            </font>
                        </Button>
                    </children>
                    <padding>
                        <Insets top="10.0"/>
                    </padding>
                </HBox>
            </children>
            <BorderPane.margin>
                <Insets bottom="10.0" right="10.0"/>
            </BorderPane.margin>
        </VBox>
    </center>
</BorderPane>
