<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<HBox alignment="CENTER" prefHeight="900.0" prefWidth="1400.0"
      xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.rendellvelasco.projectstaffingtool.controllers.LoginController">
    <children>
        <VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
              prefHeight="440.0" prefWidth="400.0">
            <children>
                <HBox alignment="CENTER">
                    <children>
                        <Label text="Login">
                            <font><Font size="36.0" /></font>
                        </Label>
                    </children>
                </HBox>

                <Label text="Username">
                    <font><Font size="18.0" /></font>
                    <VBox.margin><Insets top="10.0" /></VBox.margin>
                </Label>
                <TextField fx:id="usernameTextField">
                    <font><Font size="14.0" /></font>
                </TextField>

                <Label text="Password">
                    <font><Font size="18.0" /></font>
                    <VBox.margin><Insets top="20.0" /></VBox.margin>
                </Label>
                <PasswordField fx:id="passwordField">
                    <font><Font size="14.0" /></font>
                </PasswordField>

                <!-- Error label (hidden by default) -->
                <Label fx:id="errorLabel" text="" visible="false" textFill="RED">
                    <font><Font size="13.0" /></font>
                    <VBox.margin><Insets top="8.0" /></VBox.margin>
                </Label>

                <HBox alignment="CENTER" prefHeight="80.0" prefWidth="200.0" spacing="30.0">
                    <children>
                        <Button fx:id="loginButton" mnemonicParsing="false"
                                onAction="#onActionLoginButton" text="Login">
                            <font><Font size="14.0" /></font>
                        </Button>
                    </children>
                </HBox>
            </children>
            <padding><Insets bottom="50.0" left="50.0" right="50.0" top="50.0" /></padding>
        </VBox>
    </children>
</HBox>
