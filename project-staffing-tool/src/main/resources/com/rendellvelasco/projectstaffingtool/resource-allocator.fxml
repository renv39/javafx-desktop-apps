<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<SplitPane dividerPositions="0.5" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
           prefHeight="900.0" prefWidth="1400.0" xmlns="http://javafx.com/javafx/17.0.12"
           xmlns:fx="http://javafx.com/fxml/1">

    <items>
        <!-- ============ LEFT PANEL – New Assignment ============ -->
        <VBox alignment="CENTER">
            <children>
                <HBox alignment="CENTER" prefHeight="80.0" prefWidth="446.0">
                    <children>
                        <Label text="New Assignment">
                            <font>
                                <Font size="18.0"/>
                            </font>
                        </Label>
                    </children>
                </HBox>

                <GridPane hgap="5.0" vgap="10.0">
                    <columnConstraints>
                        <ColumnConstraints halignment="RIGHT" hgrow="SOMETIMES" maxWidth="218.0" minWidth="10.0"
                                           prefWidth="154.0"/>
                        <ColumnConstraints fillWidth="false" maxWidth="306.0" minWidth="10.0" prefWidth="292.0"/>
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints minHeight="10.0" prefHeight="35.0" vgrow="SOMETIMES"/>
                        <RowConstraints minHeight="10.0" prefHeight="35.0" vgrow="SOMETIMES"/>
                        <RowConstraints minHeight="10.0" prefHeight="35.0"/>
                        <RowConstraints minHeight="10.0" prefHeight="35.0" vgrow="SOMETIMES"/>
                        <RowConstraints minHeight="10.0" prefHeight="35.0" vgrow="SOMETIMES"/>
                        <RowConstraints minHeight="10.0" prefHeight="35.0" vgrow="SOMETIMES"/>
                    </rowConstraints>
                    <children>
                        <!-- Row 0: Skill filter -->
                        <Label text="Skill:" GridPane.rowIndex="0">
                            <font>
                                <Font size="14.0"/>
                            </font>
                        </Label>
                        <ComboBox fx:id="skillComboBox" prefWidth="200.0" GridPane.columnIndex="1"
                                  GridPane.rowIndex="0"/>

                        <!-- Row 1: Employee -->
                        <Label text="Employee:" GridPane.rowIndex="1">
                            <font>
                                <Font size="14.0"/>
                            </font>
                        </Label>
                        <ComboBox fx:id="employeeComboBox" prefWidth="200.0" GridPane.columnIndex="1"
                                  GridPane.rowIndex="1"/>

                        <!-- Row 2: Role -->
                        <Label text="Role:" GridPane.rowIndex="2">
                            <font>
                                <Font size="14.0"/>
                            </font>
                        </Label>
                        <TextField fx:id="roleTextField" GridPane.columnIndex="1" GridPane.rowIndex="2">
                            <font>
                                <Font size="14.0"/>
                            </font>
                        </TextField>

                        <!-- Row 3: New Hours -->
                        <Label text="New Hours:" GridPane.rowIndex="3">
                            <font>
                                <Font size="14.0"/>
                            </font>
                        </Label>
                        <TextField fx:id="newHoursTextField" GridPane.columnIndex="1" GridPane.rowIndex="3">
                            <font>
                                <Font size="14.0"/>
                            </font>
                        </TextField>

                        <!-- Row 5: Projected Load -->
                        <Label text="Projected Load:" GridPane.rowIndex="5">
                            <font>
                                <Font size="14.0"/>
                            </font>
                        </Label>
                        <HBox alignment="CENTER" spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="5">
                            <children>
                                <Label fx:id="projectedLoadLabel" alignment="TOP_LEFT" text="0.0 h / 40 h">
                                    <font>
                                        <Font size="14.0"/>
                                    </font>
                                </Label>
                            </children>
                            <GridPane.margin>
                                <Insets right="10.0"/>
                            </GridPane.margin>
                        </HBox>
                    </children>
                </GridPane>

                <!-- Action buttons -->
                <HBox alignment="CENTER" prefHeight="80.0" prefWidth="200.0" spacing="20.0">
                    <children>
                        <Button fx:id="assignButton" mnemonicParsing="false" onAction="#handleConfirm" text="Assign">
                            <font>
                                <Font size="14.0"/>
                            </font>
                        </Button>
                        <Button fx:id="cancelButton" mnemonicParsing="false" onAction="#handleCancel" text="Cancel">
                            <font>
                                <Font size="14.0"/>
                            </font>
                        </Button>
                    </children>
                </HBox>
            </children>
        </VBox>

        <!-- ============ RIGHT PANEL – Current Workload ============ -->
        <VBox spacing="10.0">
            <children>
                <HBox alignment="CENTER">
                    <children>
                        <Label text="Current Workload">
                            <font>
                                <Font size="18.0"/>
                            </font>
                        </Label>
                    </children>
                </HBox>
                <TableView fx:id="workloadTable" prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="workloadProjectColumn" prefWidth="120.0" text="Project"/>
                        <TableColumn fx:id="workloadRoleColumn" prefWidth="100.0" text="Role"/>
                        <TableColumn fx:id="workloadHoursColumn" prefWidth="80.0" text="Hours"/>
                        <TableColumn fx:id="workloadCostColumn" prefWidth="90.0" text="Cost"/>
                    </columns>
                </TableView>
            </children>
            <padding>
                <Insets bottom="20.0" left="10.0" right="10.0" top="20.0"/>
            </padding>
        </VBox>
    </items>
</SplitPane>
