<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<HBox alignment="CENTER" prefHeight="900.0" prefWidth="1400.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.rendellvelasco.autoloanapp.controllers.SignUpController">
    <children>
        <VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="400.0">
            <children>
                <HBox alignment="CENTER">
                    <children>
                        <Label text="Sign Up">
                            <font>
                                <Font size="36.0" />
                            </font>
                        </Label>
                    </children>
                </HBox>
                <Label text="Username">
                    <font>
                        <Font size="18.0" />
                    </font>
                    <VBox.margin>
                        <Insets top="10.0" />
                    </VBox.margin>
                </Label>
                <TextField fx:id="usernameTextField">
                    <font>
                        <Font size="14.0" />
                    </font>
                </TextField>
                <Label text="Password">
                    <font>
                        <Font size="18.0" />
                    </font>
                    <VBox.margin>
                        <Insets top="20.0" />
                    </VBox.margin>
                </Label>
                <PasswordField fx:id="passwordField">
                    <font>
                        <Font size="14.0" />
                    </font>
                </PasswordField>
                <Label layoutX="60.0" layoutY="123.0" text="Confirm Password">
                    <font>
                        <Font size="18.0" />
                    </font>
                    <VBox.margin>
                        <Insets top="20.0" />
                    </VBox.margin>
                </Label>
                <PasswordField fx:id="confirmPasswordField" layoutX="60.0" layoutY="227.0">
                    <font>
                        <Font size="14.0" />
                    </font>
                </PasswordField>
                <Label layoutX="60.0" layoutY="200.0" text="Email">
                    <font>
                        <Font size="18.0" />
                    </font>
                    <VBox.margin>
                        <Insets top="20.0" />
                    </VBox.margin>
                </Label>
                <TextField fx:id="emailTextField" layoutX="60.0" layoutY="150.0">
                    <font>
                        <Font size="14.0" />
                    </font>
                </TextField>
                <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="30.0">
                    <children>
                        <Button fx:id="backButton" mnemonicParsing="false" onAction="#onActionBackButton" text="Back">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Button>
                        <Button fx:id="signUpButton" mnemonicParsing="false" onAction="#onActionSignUpButton" text="Sign Up">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Button>
                    </children>
                    <VBox.margin>
                        <Insets top="20.0" />
                    </VBox.margin>
                </HBox>
            </children>
            <padding>
                <Insets bottom="50.0" left="50.0" right="50.0" top="30.0" />
            </padding>
        </VBox>
    </children>
</HBox>
