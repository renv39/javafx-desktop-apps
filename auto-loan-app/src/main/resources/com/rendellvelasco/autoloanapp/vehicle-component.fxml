<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox spacing="10.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.rendellvelasco.autoloanapp.controllers.VehicleController">

    <Label text="Vehicle">
        <font>
            <Font size="24.0" />
        </font>
    </Label>
    <GridPane vgap="15.0">
        <columnConstraints>
            <ColumnConstraints minWidth="-Infinity" />
            <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
            <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
            <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
        </columnConstraints>
        <rowConstraints>
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
        </rowConstraints>
        <children>
            <Label text="Type" GridPane.halignment="RIGHT" />
            <Label text="Age" GridPane.halignment="RIGHT" GridPane.rowIndex="1" />
            <Label text="Price" GridPane.halignment="RIGHT" GridPane.rowIndex="2" />
            <RadioButton fx:id="carRadio" mnemonicParsing="false" text="Car" GridPane.columnIndex="1">
                <GridPane.margin>
                    <Insets left="5.0" />
                </GridPane.margin>
            <toggleGroup>
               <ToggleGroup fx:id="typeToggleGroup" />
            </toggleGroup>
            </RadioButton>
            <RadioButton fx:id="truckRadio" mnemonicParsing="false" text="Truck" toggleGroup="$typeToggleGroup" GridPane.columnIndex="2" />
            <RadioButton fx:id="familyVanRadio" mnemonicParsing="false" text="Family Van" toggleGroup="$typeToggleGroup" GridPane.columnIndex="3" />
            <RadioButton fx:id="newRadio" mnemonicParsing="false" text="New" GridPane.columnIndex="1" GridPane.rowIndex="1">
                <GridPane.margin>
                    <Insets left="5.0" />
                </GridPane.margin>
            <toggleGroup>
               <ToggleGroup fx:id="ageToggleGroup" />
            </toggleGroup>
            </RadioButton>
            <RadioButton fx:id="usedRadio" mnemonicParsing="false" text="Used" toggleGroup="$ageToggleGroup" GridPane.columnIndex="2" GridPane.rowIndex="1" />
            <TextField fx:id="priceTextField" GridPane.columnIndex="1" GridPane.rowIndex="2">
                <GridPane.margin>
                    <Insets left="5.0" />
                </GridPane.margin>
            </TextField>
        </children>
    </GridPane>
</VBox>
