<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<Pane prefHeight="900.0" prefWidth="1400.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.rendellvelasco.autoloanapp.controllers.LoanController">
    <children>
        <VBox layoutX="447.0" layoutY="150.0" prefHeight="600" spacing="20.0" style="-fx-border-color: black;">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <fx:include fx:id="customerComponent" source="customer-component.fxml" VBox.vgrow="NEVER" />
            <fx:include fx:id="vehicleComponent" source="vehicle-component.fxml" VBox.vgrow="NEVER" />
            <Label text="Loan">
                <font>
                    <Font size="24.0" />
                </font>
            </Label>
            <GridPane hgap="5.0" layoutX="10.0" layoutY="100.0" vgap="15.0">
                <columnConstraints>
                    <ColumnConstraints minWidth="10.0" />
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                </columnConstraints>
                <rowConstraints>
                    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                </rowConstraints>
                <children>
                    <Label text="Down Payment" GridPane.halignment="RIGHT" />
                    <TextField fx:id="downPaymentField" GridPane.columnIndex="1">
                        <GridPane.margin>
                            <Insets left="5.0" />
                        </GridPane.margin>
                    </TextField>
                    <Label text="Interest Rate" GridPane.halignment="RIGHT" GridPane.rowIndex="1" />
                    <RadioButton fx:id="rate099Radio" mnemonicParsing="false" text="0.99%" GridPane.columnIndex="1" GridPane.rowIndex="1">
                        <GridPane.margin>
                            <Insets left="5.0" />
                        </GridPane.margin>
                        <toggleGroup>
                            <ToggleGroup fx:id="interestToggleGroup" />
                        </toggleGroup>
                    </RadioButton>
                    <RadioButton fx:id="rate199Radio" mnemonicParsing="false" text="1.99%" toggleGroup="$interestToggleGroup" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                    <RadioButton fx:id="rate299Radio" mnemonicParsing="false" text="2.99%" toggleGroup="$interestToggleGroup" GridPane.columnIndex="3" GridPane.rowIndex="1" />
                    <RadioButton fx:id="rateOtherRadio" alignment="TOP_RIGHT" mnemonicParsing="false" text="Other" toggleGroup="$interestToggleGroup" GridPane.columnIndex="1" GridPane.halignment="LEFT" GridPane.rowIndex="2">
                        <GridPane.margin>
                            <Insets left="5.0" />
                        </GridPane.margin>
                    </RadioButton>
                    <TextField fx:id="otherRateField" GridPane.columnIndex="2" GridPane.rowIndex="2">
                        <GridPane.margin>
                            <Insets left="5.0" />
                        </GridPane.margin>
                    </TextField>
                    <Label text="Duration" GridPane.halignment="RIGHT" GridPane.rowIndex="3" />
                    <Slider fx:id="durationSlider" blockIncrement="12.0" majorTickUnit="12.0" max="96.0" min="12.0" minorTickCount="0" showTickLabels="true" showTickMarks="true" snapToTicks="true" GridPane.columnIndex="1" GridPane.columnSpan="2" GridPane.rowIndex="3">
                        <GridPane.margin>
                            <Insets left="5.0" />
                        </GridPane.margin>
                    </Slider>
                    <Label text="Estimated Payment " GridPane.halignment="RIGHT" GridPane.rowIndex="5" />
                    <TextField fx:id="estimatedPaymentField" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="5">
                        <GridPane.margin>
                            <Insets left="5.0" />
                        </GridPane.margin>
                    </TextField>
                    <Label text="Frequency" GridPane.halignment="RIGHT" GridPane.rowIndex="4" />
                    <RadioButton fx:id="weeklyRadio" mnemonicParsing="false" text="Weekly" GridPane.columnIndex="1" GridPane.rowIndex="4">
                        <toggleGroup>
                            <ToggleGroup fx:id="frequencyToggleGroup" />
                        </toggleGroup>
                    </RadioButton>
                    <RadioButton fx:id="biWeeklyRadio" mnemonicParsing="false" text="Bi-weekly" toggleGroup="$frequencyToggleGroup" GridPane.columnIndex="2" GridPane.rowIndex="4" />
                    <RadioButton fx:id="monthlyRadio" mnemonicParsing="false" text="Monthly" toggleGroup="$frequencyToggleGroup" GridPane.columnIndex="3" GridPane.rowIndex="4" />
                </children>
            </GridPane>

            <!-- Action Buttons Row 1: Loan actions -->
            <HBox alignment="CENTER" spacing="10.0">
                <Button mnemonicParsing="false" onAction="#handleClear" text="Clear" />
                <Button mnemonicParsing="false" onAction="#handleCalculate" text="Calculate" />
                <Button mnemonicParsing="false" onAction="#handleShowAmortization" text="Amortization Schedule" />
            </HBox>

            <!-- Action Buttons Row 2: Storage actions (new for Workshop 6&7) -->
            <HBox alignment="CENTER" spacing="10.0">
                <Button mnemonicParsing="false" onAction="#handleWriteToDB" text="Write to DB" />
                <Button mnemonicParsing="false" onAction="#handleReadFromDB" text="Read from DB" />
                <Button mnemonicParsing="false" onAction="#handleWriteToFile" text="Write to File" />
                <Button mnemonicParsing="false" onAction="#handleReadFromFile" text="Read from File" />
            </HBox>

        </VBox>
    </children>
</Pane>
